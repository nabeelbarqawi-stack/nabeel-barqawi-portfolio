# Supabase (server-only — never prefix with NEXT_PUBLIC_)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (test-mode keys for local dev, live-mode in Vercel prod env vars)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Used to build absolute Stripe success/cancel redirect URLs
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Basic Auth for /admin
ADMIN_USERNAME=
ADMIN_PASSWORD=
